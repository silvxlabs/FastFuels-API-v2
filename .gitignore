# Environment and credentials
.env
.env.local
.env.*.local
.config/

# Service account keys (don't use *.json — blocks test fixtures)
**/credentials*.json
**/service-account*.json

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test / cache
.pytest_cache/
.coverage
htmlcov/

# Restricted third-party (LANL) DUET artifacts — NOT publicly distributable.
# treevox fetches the binary at runtime from a private bucket; never commit it.
services/treevox/treevox/data/*.exe

# Temporary files
*.tif
*.tiff
*.tif.aux.xml
*.tiff.aux.xml
tmp/

/.run/
/docs/
/CLAUDE.md
/AGENTS.md
/sandbox/
/.claude/
/tasks/
/services/etcher/cache/
